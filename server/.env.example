# MongoDB Atlas M0 connection string (required in production)
MONGODB_URI=

# JWT secrets (F1)
JWT_SECRET=
JWT_REFRESH_SECRET=

# First admin user, created at bootstrap if missing (F1)
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=

# Cloudinary (F2)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated allowed origins for CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5175

PORT=3000
